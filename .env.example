# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=<generate with: openssl rand -base64 32>

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<bot-token from @BotFather>
# Used to verify Telegram Login Widget HMAC (same as bot token)
TELEGRAM_BOT_SECRET=<same as TELEGRAM_BOT_TOKEN>

# ─── Claude / Anthropic ──────────────────────────────────────────────────────
# SERVER-SIDE ONLY — never expose to client or bot client bundles
ANTHROPIC_API_KEY=<sk-ant-...>

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<sk_test_...>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<pk_test_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>
STRIPE_PRO_PRICE_ID=<price_...>

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=<....apps.googleusercontent.com>
GOOGLE_CLIENT_SECRET=<...>
# AES-256 key for encrypting Google OAuth tokens at rest (32 bytes, base64)
OAUTH_TOKEN_ENCRYPTION_KEY=<generate with: openssl rand -base64 32>

# ─── Internal service secret ─────────────────────────────────────────────────
# Shared secret for web → bot /internal/send endpoint
INTERNAL_API_SECRET=<generate with: openssl rand -base64 32>
